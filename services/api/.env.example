NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/owanbe
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard-api-settings

# Dot-paths inside decoded JWT payload (Supabase: use Auth Hook or app_metadata)
JWT_TENANT_CLAIM_PATH=app_metadata.tenant_id
JWT_ROLES_CLAIM_PATH=app_metadata.roles

# Authoritative roles cache (DB lookup per user, short TTL)
ROLES_CACHE_TTL_MS=45000

# Payments / Quaser (PUBLIC_API_BASE_URL required to create payments so webhooks resolve)
# Local Quasar Financial Sandbox (default port 4000):
#   QUASER_ROUTER_BASE_URL=http://localhost:4000
#   PUBLIC_API_BASE_URL=http://localhost:8080
#   Quasar Admin webhook URL → http://localhost:8080/webhooks/quaser
# Optional: expose Owanbe only via ngrok when Quasar runs remotely:
#   PUBLIC_API_BASE_URL=https://YOUR-OWANBE-TUNNEL.ngrok-free.dev
QUASER_ROUTER_BASE_URL=http://localhost:4000
QUASER_ROUTER_API_KEY=
QUASER_WEBHOOK_SECRET=
PAYMENT_S2S_VERIFY_THRESHOLD_MINOR=500000
PAYOUT_COOLDOWN_FALLBACK_HOURS=36
PUBLIC_API_BASE_URL=http://localhost:8080
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_DEDUPE_WINDOW_MS=120000
PAYMENT_TIMEOUT_MINUTES=30
PAYOUT_TIMEOUT_MINUTES=240
FINANCE_TIMEOUT_SWEEP_MS=60000

# QFE Sprint S5: treasury settlement dual-write (default off)
QFE_DUAL_WRITE_TREASURY=false

# Phase 9 — Production Integrations
# INTEGRATIONS_MODE=production  # disables payment auto-stub; requires Quaser URL
INTEGRATIONS_MODE=development
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=Owanbe <noreply@owanbe.app>
NOTIFICATION_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=owanbe-media
