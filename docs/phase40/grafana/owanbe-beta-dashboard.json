{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "title": "API errors (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(api_errors_total[5m])) by (code)", "legendFormat": "{{code}}" }]
    },
    {
      "title": "Invitations sent vs failed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(invitations_sent_total[1h]))", "legendFormat": "sent" },
        { "expr": "sum(rate(invitations_failed_total[1h]))", "legendFormat": "failed" }
      ]
    },
    {
      "title": "Payment captures (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum(increase(payments_captured_total[24h]))" }]
    },
    {
      "title": "RSVP failures (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [{ "expr": "sum(increase(rsvp_failed_total[1h]))" }]
    },
    {
      "title": "owanbe_up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "owanbe_up" }]
    },
    {
      "title": "Notifications failed by channel",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [{ "expr": "sum(rate(notifications_failed_total[1h])) by (channel)", "legendFormat": "{{channel}}" }]
    }
  ],
