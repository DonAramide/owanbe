# Staging API — copy to services/api/.env on staging host (do not commit secrets)
NODE_ENV=production
PORT=8080
DATABASE_URL=postgres://USER:PASS@HOST:5432/owanbe

SUPABASE_JWT_SECRET=
JWT_TENANT_CLAIM_PATH=app_metadata.tenant_id
JWT_ROLES_CLAIM_PATH=app_metadata.roles

INTEGRATIONS_MODE=production
QUASER_ROUTER_BASE_URL=
QUASER_ROUTER_API_KEY=
QUASER_WEBHOOK_SECRET=
PUBLIC_API_BASE_URL=https://api.staging.owanbe.com
CORS_ORIGINS=https://app.staging.owanbe.com,https://vendors.staging.owanbe.com,https://admin.staging.owanbe.com

ALERT_WEBHOOK_URL=
ALERT_DEDUPE_WINDOW_MS=120000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=owanbe-media
