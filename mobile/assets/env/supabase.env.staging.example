# Staging Flutter runtime config — copy to assets/env/supabase.env before `flutter build web --release`
# Do NOT commit real keys to git; inject via CI secret or local override.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

OWANBE_API_BASE=https://api.staging.owanbe.com/v1
# OWANBE_TENANT_ID=11111111-1111-4111-8111-111111111111

ALLOW_MOCK_PERSISTENCE_FALLBACK=false
