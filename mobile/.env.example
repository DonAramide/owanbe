# Owanbe loads Supabase from bundled assets by default:
#   assets/env/supabase.env
# (see lib/supabase/bootstrap.dart)
#
# Optional: for local overrides without editing assets, you could switch bootstrap
# to load ".env" from the project root — keep that file gitignored (see .gitignore).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NEVER in the Flutter app:
# - sb_secret_* / service_role JWT (backend / Edge Functions only)

# OWANBE_API_BASE=http://localhost:8080/v1
# OWANBE_TENANT_ID=11111111-1111-4111-8111-111111111111   # dev seed tenant (Phase 5.1)
# OWANBE_ORGANIZER_USER_ID=22222222-2222-4222-8222-222222222222   # organizer owner (Phase 5.2)
# ALLOW_MOCK_FINANCE_FALLBACK=false   # vendor finance: require API (Phase 5.3C)
